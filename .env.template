# Environment variables template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================
# DATABASE
# ============================================
DB_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://securityuser:${DB_PASSWORD}@postgres:5432/security_monitoring

# ============================================
# API & AUTHENTICATION
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=changeme_api_secret_key_min_32_chars_length_required
JWT_SECRET=changeme_jwt_secret_min_32_chars_length_required

# Agent API Token (for agents to authenticate to central server)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AGENT_API_TOKEN=changeme_agent_token_should_be_long_and_random

# ============================================
# ENCRYPTION
# ============================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================
# DASHBOARD
# ============================================
DASHBOARD_SECRET_KEY=changeme_dashboard_secret_key_32_chars_min

# ============================================
# CHROMA VECTOR DB
# ============================================
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# SECURITY POLICIES
# ============================================
# Data retention in days
DATA_RETENTION_DAYS=90

# Max alert age before auto-archival (days)
ALERT_RETENTION_DAYS=180

# Enable audit logging
ENABLE_AUDIT_LOG=true

# ============================================
# AGENT CONFIGURATION
# ============================================
# Central server URL (for agents)
CENTRAL_SERVER_URL=https://central-server:8000

# Agent collection interval (seconds)
COLLECTION_INTERVAL=30

# Hostname identifier
HOSTNAME=

# ============================================
# ML MODEL SETTINGS
# ============================================
# Anomaly detection threshold (0.0 - 1.0)
ANOMALY_THRESHOLD=0.7

# Malware classification threshold
MALWARE_THRESHOLD=0.8

# ============================================
# CORS & ALLOWED ORIGINS
# ============================================
ALLOWED_ORIGINS=https://localhost:8443,https://dashboard:443

# ============================================
# EMBEDDING MODEL
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternatives:
# - sentence-transformers/all-mpnet-base-v2 (higher quality, slower)
# - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (multilingual)

# ============================================
# DEVELOPMENT OPTIONS (DISABLE IN PRODUCTION)
# ============================================
DEBUG_MODE=false
SKIP_SSL_VERIFY=false
